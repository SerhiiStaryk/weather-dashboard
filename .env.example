# Example environment variables for local development
# Copy this file to `.env.local` and populate the values (do NOT commit secrets)

# OpenWeatherMap API key (required)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: override API base URL (defaults to https://api.openweathermap.org)
VITE_API_BASE_URL=https://api.openweathermap.org

# Chat service URL used by ChatWindow component (optional)
VITE_CHAT_API_URL=https://example.com/chat

